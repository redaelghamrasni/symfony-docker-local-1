{% extends 'base.html.twig' %}
{% import 'components/ui.html.twig' as ui %}

{% block title %}Articles - MonApp{% endblock %}

{% block body %}
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-zinc-900 mb-2">
            Mes Articles
        </h1>
        <p class="text-zinc-600">
            Gérez et consultez tous vos articles
        </p>
    </div>

    {# Exemple de contenu avec vos composants #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {{ ui.card('Premier article', 'Ceci est un exemple d\'article') }}
        {{ ui.card('Deuxième article', 'Un autre article intéressant') }}
        {{ ui.card('Troisième article', 'Encore un article génial') }}
    </div>
{% endblock %}