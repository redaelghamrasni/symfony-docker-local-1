{% extends 'admin/base.html.twig' %}

{% block title %}{{ 'admin.settings.title'|trans }} - Admin{% endblock %}
{% block page_title %}{{ 'admin.settings.title'|trans }}{% endblock %}

{% block content %}
<div style="max-width: 720px;">
    <form method="POST" action="{{ path('admin_settings_index') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('admin_settings') }}">

        <div style="background: #fff; border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden; margin-bottom: 24px;">
            <div style="padding: 20px 24px; border-bottom: 1px solid #e2e8f0; background: #f8fafc;">
                <h2 style="margin: 0; font-size: 1rem; font-weight: 600; color: #0f172a;">{{ 'admin.settings.general_section'|trans }}</h2>
            </div>

            <div style="padding: 24px; display: flex; flex-direction: column; gap: 20px;">
                {% for setting in settings %}
                    <div>
                        <label for="setting_{{ setting.key }}" style="display: block; font-size: 0.875rem; font-weight: 600; color: #374151; margin-bottom: 6px;">
                            {{ setting.label }}
                        </label>
                        {% if setting.type == 'number' %}
                            <input type="number" step="0.01" min="0"
                                   id="setting_{{ setting.key }}"
                                   name="settings[{{ setting.key }}]"
                                   value="{{ setting.value ?? '' }}"
                                   placeholder="0.00"
                                   style="width: 100%; max-width: 240px; padding: 9px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.875rem; color: #0f172a; background: #f9fafb;">
                        {% elseif setting.type == 'textarea' %}
                            <textarea id="setting_{{ setting.key }}"
                                      name="settings[{{ setting.key }}]"
                                      rows="4"
                                      style="width: 100%; padding: 9px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.875rem; color: #0f172a; background: #f9fafb; resize: vertical;">{{ setting.value ?? '' }}</textarea>
                        {% else %}
                            <input type="text"
                                   id="setting_{{ setting.key }}"
                                   name="settings[{{ setting.key }}]"
                                   value="{{ setting.value ?? '' }}"
                                   style="width: 100%; max-width: 400px; padding: 9px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 0.875rem; color: #0f172a; background: #f9fafb;">
                        {% endif %}
                        {% if setting.key == 'shipping.free_threshold' %}
                            <p style="margin: 4px 0 0; font-size: 0.8rem; color: #64748b;">{{ 'admin.settings.free_threshold_hint'|trans }}</p>
                        {% endif %}
                    </div>
                {% else %}
                    <p style="color: #94a3b8; font-size: 0.875rem;">{{ 'admin.settings.no_settings'|trans }}</p>
                {% endfor %}
            </div>
        </div>

        <button type="submit" style="
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 24px; background: #0f172a; color: #fff;
            border: none; border-radius: 8px; font-size: 0.875rem; font-weight: 600;
            cursor: pointer; transition: background 0.15s;
        " onmouseover="this.style.background='#1e293b'" onmouseout="this.style.background='#0f172a'">
            <i class="bi bi-check-lg"></i>
            {{ 'admin.settings.save'|trans }}
        </button>
    </form>
</div>
{% endblock %}
