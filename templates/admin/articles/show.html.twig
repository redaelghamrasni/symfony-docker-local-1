{% extends 'admin/base.html.twig' %}

{% block title %}{{ article.title|slice(0,40) }} - Admin{% endblock %}
{% block page_title %}{{ 'admin.articles.show.title'|trans }}{% endblock %}

{% block breadcrumb %}
<p style="margin: -8px 0 20px 0; font-size: 12px; color: #8a9ab5;">
    <a href="{{ path('admin_articles_index') }}" style="color: #8a9ab5; text-decoration: none;">{{ 'admin.nav.articles'|trans }}</a>
    &nbsp;/&nbsp;{{ article.title|slice(0, 40) }}{% if article.title|length > 40 %}…{% endif %}
</p>
{% endblock %}

{% block content %}

{% set _referer = app.request.query.get('referer') %}
{% set backUrl = (
    _referer is not empty and
    _referer starts with '/' and
    'cart' not in _referer and
    'checkout' not in _referer
) ? _referer : path('admin_articles_index') %}

<div style="display: grid; grid-template-columns: 1fr 300px; gap: 24px; align-items: start;">

    {# ── Left column ────────────────────────────────────────────────── #}
    <div style="display: flex; flex-direction: column; gap: 24px;">

        {# Translations card with FR/EN tabs #}
        <div style="background: white; border: 1px solid #d6dde6; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
            <div style="padding: 16px 24px; background: #f8fafc; border-bottom: 1px solid #d6dde6; display: flex; align-items: center; justify-content: space-between;">
                <h2 style="margin: 0; font-size: 13px; font-weight: 700; color: #1a2340; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.form.content_title'|trans }}</h2>
                <div style="display: flex; gap: 4px;">
                    {% for locale in ['fr', 'en'] %}
                        <button type="button"
                            class="lang-tab-show"
                            data-locale="{{ locale }}"
                            onclick="switchShowTab('{{ locale }}')"
                            style="padding: 5px 14px; border-radius: 5px; font-size: 12px; font-weight: 700; letter-spacing: 0.05em; border: 1px solid #d6dde6; cursor: pointer; transition: background 0.15s; text-transform: uppercase; background: {{ locale == 'fr' ? '#1a2340' : '#fff' }}; color: {{ locale == 'fr' ? '#fff' : '#8a9ab5' }};">
                            {{ locale == 'fr' ? '🇫🇷' : '🇬🇧' }} {{ locale|upper }}
                        </button>
                    {% endfor %}
                </div>
            </div>
            <div style="padding: 28px 24px;">
                {% for locale in ['fr', 'en'] %}
                    {% set t = article.getTranslation(locale) %}
                    <div class="lang-panel-show" data-locale="{{ locale }}" style="display: {{ locale == 'fr' ? 'block' : 'none' }};">
                        <h3 style="margin: 0 0 12px 0; font-size: 18px; font-weight: 700; color: #1a2340;">
                            {{ t ? t.title : article.title }}
                            <span style="margin-left: 8px; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 10px; background: {{ locale == 'fr' ? '#e8f0fb' : '#f0fdf4' }}; color: {{ locale == 'fr' ? '#1a56db' : '#16a34a' }}; vertical-align: middle; text-transform: uppercase;">{{ locale|upper }}</span>
                        </h3>
                        <div style="font-size: 15px; line-height: 1.8; color: #374151; white-space: pre-wrap; word-wrap: break-word;">
                            {{ t ? t.content : article.content }}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

    </div>

    {# ── Right sidebar ───────────────────────────────────────────────── #}
    <div style="display: flex; flex-direction: column; gap: 16px;">

        {# ① Back — navigation, always at the top #}
        <a href="{{ backUrl }}" class="btn-action-secondary" style="justify-content: center;">
            <i class="bi bi-arrow-left"></i> {{ 'common.back'|trans }}
        </a>

        {# ② Operations — Edit + Delete #}
        <div style="display: flex; flex-direction: column; gap: 8px;">
            <a href="{{ path('admin_articles_edit', {id: article.id}) }}{% if _referer is not empty and _referer starts with '/' %}?referer={{ _referer|url_encode }}{% endif %}" class="btn-action-primary" style="justify-content: center;">
                <i class="bi bi-pencil"></i> {{ 'common.edit'|trans }}
            </a>
            <form method="POST" action="{{ path('admin_articles_delete', {id: article.id}) }}"
                  onsubmit="return confirm('{{ 'admin.articles.index.confirm_delete'|trans|e('js') }}');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                <button type="submit" class="btn-danger" style="width: 100%; justify-content: center;">
                    <i class="bi bi-trash3"></i> {{ 'common.delete'|trans }}
                </button>
            </form>
        </div>

        {# ③ Meta info #}
        <div style="background: white; border: 1px solid #d6dde6; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
            <div style="padding: 14px 20px; background: #f8fafc; border-bottom: 1px solid #d6dde6;">
                <h2 style="margin: 0; font-size: 13px; font-weight: 700; color: #1a2340; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.show.details'|trans }}</h2>
            </div>
            <div style="padding: 20px; display: flex; flex-direction: column; gap: 14px;">

                {# SKU #}
                {% if article.sku %}
                <div>
                    <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 600; color: #8a9ab5; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.show.sku'|trans }}</p>
                    <span style="font-family: monospace; font-size: 13px; font-weight: 700; color: #1a2340; background: #f1f5f9; padding: 3px 8px; border-radius: 4px; border: 1px solid #e2e8f0;">{{ article.sku }}</span>
                </div>
                {% endif %}

                {# ID #}
                <div>
                    <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 600; color: #8a9ab5; text-transform: uppercase; letter-spacing: 0.05em;">ID</p>
                    <p style="margin: 0; font-size: 14px; color: #1a2340;">#{{ article.id }}</p>
                </div>

                {# Category #}
                <div>
                    <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 600; color: #8a9ab5; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'article_form.category_label'|trans }}</p>
                    {% if article.category %}
                        <span style="padding: 3px 10px; border-radius: 999px; background: #ede9fe; color: #6d28d9; font-size: 12px; font-weight: 600;">{{ article.category.name }}</span>
                    {% else %}
                        <span style="color: #cbd5e1; font-size: 13px;">—</span>
                    {% endif %}
                </div>

                {# Created at #}
                <div>
                    <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 600; color: #8a9ab5; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.orders.show.created'|trans }}</p>
                    <p style="margin: 0; font-size: 13px; color: #1a2340;">{{ article.createdAt|date('d/m/Y') }}</p>
                </div>

            </div>
        </div>

        {# ④ Pricing card #}
        <div style="background: white; border: 1px solid #d6dde6; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
            <div style="padding: 14px 20px; background: #f8fafc; border-bottom: 1px solid #d6dde6;">
                <h2 style="margin: 0; font-size: 13px; font-weight: 700; color: #1a2340; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.show.pricing'|trans }}</h2>
            </div>
            <div style="padding: 20px; display: flex; flex-direction: column; gap: 16px;">

                {# Base price — always shown #}
                <div>
                    <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 600; color: #8a9ab5; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.show.base_price'|trans }}</p>
                    {% if article.hasActivePromotion %}
                        <p style="margin: 0; font-size: 18px; font-weight: 700; color: #94a3b8; text-decoration: line-through;">${{ article.price|number_format(2) }}</p>
                    {% else %}
                        <p style="margin: 0; font-size: 22px; font-weight: 700; color: #1a2340;">${{ article.price|number_format(2) }}</p>
                    {% endif %}
                </div>

                {% if article.hasActivePromotion %}
                    {% set promo = article.activePromotion %}
                    {% set savings = (article.price - article.effectivePrice)|abs %}

                    {# Active promotion badge #}
                    <div style="padding: 10px 12px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 6px;">
                        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 600; color: #16a34a; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.show.active_promotion'|trans }}</p>
                        <p style="margin: 0; font-size: 13px; font-weight: 700; color: #166534;">
                            ✓ {{ promo.name }}
                        </p>
                        <p style="margin: 4px 0 0 0; font-size: 12px; color: #16a34a;">
                            {% if promo.type == 'percent_off' %}
                                {{ 'admin.promotions.type.percent_off'|trans }} — {{ promo.value }}%
                            {% elseif promo.type == 'amount_off' %}
                                {{ 'admin.promotions.type.amount_off'|trans }} — ${{ promo.value|number_format(2) }}
                            {% elseif promo.type == 'fixed_price' %}
                                {{ 'admin.promotions.type.fixed_price'|trans }} — ${{ promo.value|number_format(2) }}
                            {% endif %}
                        </p>
                    </div>

                    {# Promotional price #}
                    <div>
                        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 600; color: #8a9ab5; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.show.promotional_price'|trans }}</p>
                        <p style="margin: 0; font-size: 22px; font-weight: 700; color: #ef4444;">${{ article.effectivePrice|number_format(2) }}</p>
                        <p style="margin: 4px 0 0 0; font-size: 12px; color: #16a34a; font-weight: 600;">
                            {{ 'admin.articles.show.savings'|trans }} : ${{ savings|number_format(2) }}
                        </p>
                    </div>

                {% else %}
                    {# No active promotion — list assigned promotions if any #}
                    {% if article.promotions|length > 0 %}
                    <div style="border-top: 1px solid #f1f5f9; padding-top: 14px;">
                        <p style="margin: 0 0 8px 0; font-size: 11px; font-weight: 600; color: #8a9ab5; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.form.promotions_label'|trans }}</p>
                        <div style="display: flex; flex-direction: column; gap: 4px;">
                            {% for p in article.promotions %}
                                <span style="font-size: 12px; padding: 3px 8px; border-radius: 4px; background: #f1f5f9; color: #64748b; font-weight: 600;">
                                    ○ {{ p.name }}
                                </span>
                            {% endfor %}
                        </div>
                        <p style="margin: 8px 0 0 0; font-size: 11px; color: #94a3b8; font-style: italic;">{{ 'admin.articles.show.no_active_promotion'|trans }}</p>
                    </div>
                    {% endif %}
                {% endif %}

            </div>
        </div>

        {# ⑤ Back — also at the bottom for long pages #}
        <a href="{{ backUrl }}" class="btn-action-secondary" style="justify-content: center;">
            <i class="bi bi-arrow-left"></i> {{ 'common.back'|trans }}
        </a>

    </div>
</div>

<script>
function switchShowTab(locale) {
    document.querySelectorAll('.lang-tab-show').forEach(function(btn) {
        var active = btn.dataset.locale === locale;
        btn.style.background  = active ? '#1a2340' : '#fff';
        btn.style.color       = active ? '#fff'    : '#8a9ab5';
        btn.style.borderColor = active ? '#1a2340' : '#d6dde6';
    });
    document.querySelectorAll('.lang-panel-show').forEach(function(panel) {
        panel.style.display = panel.dataset.locale === locale ? 'block' : 'none';
    });
}
</script>

{% endblock %}
