{% set statusLabels = {
    'pending':    'admin.orders.show.status_pending'|trans,
    'processing': 'admin.orders.show.status_processing'|trans,
    'completed':  'admin.orders.show.status_completed'|trans,
    'cancelled':  'admin.orders.show.status_cancelled'|trans
} %}
{% set statusStyles = {
    'pending':    'background:#fef9c3;color:#854d0e;',
    'processing': 'background:#dbeafe;color:#1e40af;',
    'completed':  'background:#dcfce7;color:#166534;',
    'cancelled':  'background:#fee2e2;color:#991b1b;'
} %}
{% for order in orders %}
<tr style="border-bottom: 1px solid #e2e8f0;">
    <td style="padding: 14px 16px; color: #64748b; font-size: 13px; font-weight: 600;">#{{ order.id }}</td>
    <td style="padding: 14px 16px; color: #0f172a; font-weight: 500;">
        {{ order.customerFirstName }} {{ order.customerLastName }}
    </td>
    <td style="padding: 14px 16px; color: #64748b; font-size: 13px;">{{ order.customerEmail }}</td>
    <td style="padding: 14px 16px; color: #64748b; font-size: 13px;">{{ order.items|length }}</td>
    <td style="padding: 14px 16px; text-align: right; font-weight: 600; color: #0f172a;">
        {{ order.total|number_format(2, ',', ' ') }} $
    </td>
    <td style="padding: 14px 16px; text-align: center;">
        <span style="padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 600; {{ statusStyles[order.status] ?? '' }}">
            {{ statusLabels[order.status] ?? order.status|capitalize }}
        </span>
    </td>
    <td style="padding: 14px 16px; color: #64748b; font-size: 13px;">
        {{ order.createdAt|date('Y-m-d H:i') }}
    </td>
    <td style="padding: 14px 16px; text-align: right;">
        <a href="{{ path('admin_orders_show', {id: order.id}) }}" class="btn-action-secondary" style="font-size: 12px; padding: 5px 12px;">
            <i class="bi bi-eye"></i> {{ 'admin.orders.index.view'|trans }}
        </a>
    </td>
</tr>
{% endfor %}
