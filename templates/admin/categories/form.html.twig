{% extends 'admin/base.html.twig' %}

{% block title %}{{ isEdit ? 'common.edit'|trans : 'admin.categories.form.new_category'|trans }} - Admin{% endblock %}
{% block page_title %}{{ isEdit ? 'common.edit'|trans : 'admin.categories.form.new_category'|trans }}{% endblock %}

{% block breadcrumb %}
<p style="margin: -8px 0 20px 0; font-size: 12px; color: #8a9ab5;">
    <a href="{{ path('admin_categories_index') }}" style="color: #8a9ab5; text-decoration: none;">{{ 'admin.categories.index.breadcrumb'|trans }}</a>
    &nbsp;/&nbsp;{{ isEdit ? category.name : 'admin.categories.form.new_category'|trans }}
</p>
{% endblock %}

{% block content %}

{{ form_start(form, {'attr': {'id': 'category-form', 'novalidate': 'novalidate'}}) }}

<div style="display: flex; justify-content: flex-end; gap: 10px; margin-bottom: 24px;">
    <a href="{{ path('admin_categories_index') }}" class="btn-action-secondary">
        <i class="bi bi-x-lg"></i> {{ 'common.cancel'|trans }}
    </a>
    <button type="submit" form="category-form" class="btn-action-primary">
        <i class="bi bi-check-lg"></i> {{ isEdit ? 'common.save_changes'|trans : 'admin.categories.form.create_btn'|trans }}
    </button>
</div>

<div style="background: white; border: 1px solid #d6dde6; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); margin-bottom: 24px;">
    <div style="padding: 16px 24px; background: #f8fafc; border-bottom: 1px solid #d6dde6;">
        <h2 style="margin: 0; font-size: 13px; font-weight: 700; color: #1a2340; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.categories.form.info_title'|trans }}</h2>
    </div>
    <div style="padding: 28px 24px;">
        <label style="display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;">
            {{ 'admin.categories.form.name_label'|trans }}
        </label>
        {{ form_widget(form.name, {
            'attr': {
                'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; color: #1a2340; background: #f8fafc; box-sizing: border-box;',
                'placeholder': 'admin.categories.form.name_placeholder'|trans,
            }
        }) }}
        <div style="color: #dc2626; font-size: 13px; margin-top: 4px;">{{ form_errors(form.name) }}</div>
        {% if isEdit %}
            <p style="margin: 8px 0 0; font-size: 12px; color: #94a3b8;">Slug: {{ category.slug }}</p>
        {% endif %}
    </div>
</div>

<div style="display: flex; justify-content: flex-end; gap: 10px; padding-bottom: 16px;">
    <a href="{{ path('admin_categories_index') }}" class="btn-action-secondary">
        <i class="bi bi-x-lg"></i> {{ 'common.cancel'|trans }}
    </a>
    <button type="submit" form="category-form" class="btn-action-primary">
        <i class="bi bi-check-lg"></i> {{ isEdit ? 'common.save_changes'|trans : 'admin.categories.form.create_btn'|trans }}
    </button>
</div>

{{ form_end(form) }}

{% endblock %}
