{% extends 'admin/base.html.twig' %}

{% block title %}{{ isEdit ? 'common.edit'|trans : 'admin.promotions.form.new_promotion'|trans }} - Admin{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
    var labelSelected  = {{ ('admin.promotions.form.articles_selected_count')|trans({'%count%': '__N__'})|json_encode|raw }};
    var select         = document.querySelector('[name$="[articles][]"]') || document.querySelector('select[multiple]');
    var grid           = document.getElementById('picker-grid');
    var countBadge     = document.getElementById('picker-count');

    function getSelectedIds() {
        return Array.from(select.selectedOptions).map(o => o.value);
    }

    function updateCount() {
        var n = getSelectedIds().length;
        countBadge.textContent = labelSelected.replace('__N__', n);
        countBadge.style.background = n > 0 ? '#e8f0fb' : '#f1f5f9';
        countBadge.style.color      = n > 0 ? '#1a56db' : '#64748b';
    }

    function buildCard(option) {
        var isSelected = option.selected;
        var card = document.createElement('div');
        card.dataset.value = option.value;
        card.dataset.label = option.text.toLowerCase();
        card.style.cssText = [
            'padding: 10px 14px',
            'border-radius: 7px',
            'border: 2px solid ' + (isSelected ? '#1a56db' : '#d6dde6'),
            'background: ' + (isSelected ? '#eef3fd' : '#f8fafc'),
            'cursor: pointer',
            'transition: border-color 0.15s, background 0.15s',
            'display: flex',
            'align-items: center',
            'gap: 10px',
            'user-select: none',
        ].join(';');

        var checkbox = document.createElement('div');
        checkbox.style.cssText = [
            'width: 16px',
            'height: 16px',
            'min-width: 16px',
            'border-radius: 4px',
            'border: 2px solid ' + (isSelected ? '#1a56db' : '#c0cad8'),
            'background: ' + (isSelected ? '#1a56db' : '#fff'),
            'display: flex',
            'align-items: center',
            'justify-content: center',
            'transition: background 0.15s, border-color 0.15s',
        ].join(';');
        if (isSelected) {
            checkbox.innerHTML = '<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        }

        var label = document.createElement('span');
        label.textContent = option.text;
        label.style.cssText = 'font-size: 13px; font-weight: 600; color: ' + (isSelected ? '#1a3080' : '#374155') + '; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;';

        card.appendChild(checkbox);
        card.appendChild(label);

        card.addEventListener('click', function () {
            var opt = select.querySelector('option[value="' + card.dataset.value + '"]');
            opt.selected = !opt.selected;
            refreshCard(card, opt.selected);
            updateCount();
        });

        return card;
    }

    function refreshCard(card, selected) {
        card.style.borderColor  = selected ? '#1a56db' : '#d6dde6';
        card.style.background   = selected ? '#eef3fd' : '#f8fafc';
        var cb = card.firstChild;
        cb.style.borderColor    = selected ? '#1a56db' : '#c0cad8';
        cb.style.background     = selected ? '#1a56db' : '#fff';
        cb.innerHTML = selected
            ? '<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>'
            : '';
        card.lastChild.style.color = selected ? '#1a3080' : '#374155';
    }

    function buildGrid() {
        Array.from(select.options).forEach(function (opt) {
            grid.appendChild(buildCard(opt));
        });
        updateCount();
    }

    window.pickerFilter = function (query) {
        var q = query.toLowerCase().trim();
        Array.from(grid.children).forEach(function (card) {
            card.style.display = (!q || card.dataset.label.includes(q)) ? '' : 'none';
        });
    };

    window.pickerSelectAll = function () {
        Array.from(select.options).forEach(function (opt) { opt.selected = true; });
        Array.from(grid.children).forEach(function (card) { refreshCard(card, true); });
        updateCount();
    };

    window.pickerClearAll = function () {
        Array.from(select.options).forEach(function (opt) { opt.selected = false; });
        Array.from(grid.children).forEach(function (card) { refreshCard(card, false); });
        updateCount();
    };

    buildGrid();
})();
</script>
{% endblock %}
{% block page_title %}{{ isEdit ? 'common.edit'|trans : 'admin.promotions.form.new_promotion'|trans }}{% endblock %}

{% block breadcrumb %}
<p style="margin: -8px 0 20px 0; font-size: 12px; color: #8a9ab5;">
    <a href="{{ path('admin_promotions_index') }}" style="color: #8a9ab5; text-decoration: none;">{{ 'admin.promotions.index.breadcrumb'|trans }}</a>
    &nbsp;/&nbsp;{{ isEdit ? promotion.name : 'admin.promotions.form.new_promotion'|trans }}
</p>
{% endblock %}

{% block content %}

{{ form_start(form, {'attr': {'id': 'promotion-form', 'novalidate': 'novalidate'}}) }}

<div style="display: flex; justify-content: flex-end; gap: 10px; margin-bottom: 24px;">
    <a href="{{ path('admin_promotions_index') }}" class="btn-action-secondary">
        <i class="bi bi-x-lg"></i> {{ 'common.cancel'|trans }}
    </a>
    <button type="submit" form="promotion-form" class="btn-action-primary">
        <i class="bi bi-check-lg"></i> {{ isEdit ? 'common.save_changes'|trans : 'admin.promotions.form.create_btn'|trans }}
    </button>
</div>

{# General info #}
<div style="background: white; border: 1px solid #d6dde6; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); margin-bottom: 24px;">
    <div style="padding: 16px 24px; background: #f8fafc; border-bottom: 1px solid #d6dde6;">
        <h2 style="margin: 0; font-size: 13px; font-weight: 700; color: #1a2340; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.promotions.form.info_title'|trans }}</h2>
    </div>
    <div style="padding: 28px 24px; display: flex; flex-direction: column; gap: 20px;">

        <div>
            <label style="display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;">{{ 'admin.promotions.form.name_label'|trans }}</label>
            {{ form_widget(form.name, {'attr': {'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; background: #f8fafc; box-sizing: border-box;'}}) }}
            <div style="color: #dc2626; font-size: 13px; margin-top: 4px;">{{ form_errors(form.name) }}</div>
        </div>

        <div>
            <label style="display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;">{{ 'admin.promotions.form.description_label'|trans }}</label>
            {{ form_widget(form.description, {'attr': {'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; background: #f8fafc; box-sizing: border-box; resize: vertical;'}}) }}
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div>
                <label style="display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;">{{ 'admin.promotions.form.type_label'|trans }}</label>
                {{ form_widget(form.type, {'attr': {'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; background: #f8fafc; box-sizing: border-box;'}}) }}
            </div>
            <div>
                <label style="display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;">{{ 'admin.promotions.form.value_label'|trans }}</label>
                {{ form_widget(form.value, {'attr': {'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; background: #f8fafc; box-sizing: border-box;'}}) }}
                <div style="color: #dc2626; font-size: 13px; margin-top: 4px;">{{ form_errors(form.value) }}</div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div>
                <label style="display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;">{{ 'admin.promotions.form.starts_at_label'|trans }}</label>
                {{ form_widget(form.startsAt, {'attr': {'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; background: #f8fafc; box-sizing: border-box;'}}) }}
            </div>
            <div>
                <label style="display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;">{{ 'admin.promotions.form.ends_at_label'|trans }}</label>
                {{ form_widget(form.endsAt, {'attr': {'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; background: #f8fafc; box-sizing: border-box;'}}) }}
            </div>
        </div>

        <div style="display: flex; align-items: center; gap: 0.75rem;">
            {{ form_widget(form.isActive) }}
            <label style="font-size: 14px; font-weight: 600; color: #374155;">{{ 'admin.promotions.form.is_active_label'|trans }}</label>
        </div>

    </div>
</div>

{# Articles picker #}
<div style="background: white; border: 1px solid #d6dde6; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); margin-bottom: 24px;">
    <div style="padding: 16px 24px; background: #f8fafc; border-bottom: 1px solid #d6dde6; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;">
        <h2 style="margin: 0; font-size: 13px; font-weight: 700; color: #1a2340; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.promotions.form.articles_label'|trans }}</h2>
        <div style="display: flex; align-items: center; gap: 10px;">
            <span id="picker-count" style="font-size: 12px; font-weight: 600; color: #64748b; background: #e8f0fb; padding: 3px 10px; border-radius: 10px;"></span>
            <button type="button" onclick="pickerSelectAll()" style="font-size: 12px; color: #1a56db; background: none; border: none; cursor: pointer; padding: 0; font-weight: 600;">{{ 'admin.promotions.form.articles_select_all'|trans }}</button>
            <span style="color: #d6dde6;">|</span>
            <button type="button" onclick="pickerClearAll()" style="font-size: 12px; color: #64748b; background: none; border: none; cursor: pointer; padding: 0; font-weight: 600;">{{ 'admin.promotions.form.articles_clear_all'|trans }}</button>
        </div>
    </div>
    <div style="padding: 16px 24px 4px;">
        <div style="position: relative;">
            <i class="bi bi-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #8a9ab5; font-size: 14px; pointer-events: none;"></i>
            <input type="text" id="picker-search"
                   placeholder="{{ 'admin.promotions.form.articles_search'|trans }}"
                   oninput="pickerFilter(this.value)"
                   style="width: 100%; padding: 9px 14px 9px 36px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 14px; background: #f8fafc; box-sizing: border-box; outline: none;">
        </div>
    </div>
    <div id="picker-grid"
         style="padding: 12px 24px 20px; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px; max-height: 380px; overflow-y: auto;">
    </div>

    {# Hidden native select — drives form submission #}
    <div style="display: none;">
        {{ form_widget(form.articles) }}
    </div>
</div>

<div style="display: flex; justify-content: flex-end; gap: 10px; padding-bottom: 16px;">
    <a href="{{ path('admin_promotions_index') }}" class="btn-action-secondary">
        <i class="bi bi-x-lg"></i> {{ 'common.cancel'|trans }}
    </a>
    <button type="submit" form="promotion-form" class="btn-action-primary">
        <i class="bi bi-check-lg"></i> {{ isEdit ? 'common.save_changes'|trans : 'admin.promotions.form.create_btn'|trans }}
    </button>
</div>

{{ form_end(form) }}

{% endblock %}
