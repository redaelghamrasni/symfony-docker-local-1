<div style="font-family: Arial, sans-serif; color: #1f2937;">
    <h1>{{ 'email.password_reset.title'|trans }}</h1>
    <p>{{ 'email.password_reset.greeting'|trans({'%name%': user.firstName}) }}</p>
    <p>{{ 'email.password_reset.message'|trans }}</p>
    <p>{{ 'email.password_reset.instruction'|trans }}</p>

    <p style="margin: 20px 0; text-align: center;">
        <a href="{{ resetLink }}" style="display: inline-block; padding: 12px 24px; background-color: #0f172a; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">
            {{ 'email.password_reset.reset_btn'|trans }}
        </a>
    </p>

    <p><strong>{{ 'email.password_reset.expiry'|trans }}</strong></p>
    <p>{{ 'email.password_reset.no_request'|trans }}</p>

    <hr style="margin: 30px 0; border: none; border-top: 1px solid #d1d5db;">
    <p style="font-size: 12px; color: #6b7280;">
        {{ 'email.password_reset.copy_url'|trans }}<br>
        <code style="background: #f3f4f6; padding: 4px 8px; border-radius: 2px; word-break: break-all;">{{ resetLink }}</code>
    </p>
    <p style="font-size: 12px; color: #6b7280;">{{ 'email.password_reset.goodbye'|trans }}<br>{{ 'email.password_reset.team'|trans({'%app%': 'nav.app_name'|trans}) }}</p>
</div>
