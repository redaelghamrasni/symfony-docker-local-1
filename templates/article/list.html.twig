{% extends 'base.html.twig' %}
{% block title %}{{ 'articles.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Category bar ─────────────────────────────────── */
        .category-bar {
            position: sticky;
            top: 64px;
            z-index: 40;
            background: white;
            border-bottom: 1px solid #e5e7eb;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }
        .category-bar-inner {
            max-width: 1280px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            gap: 8px;
            overflow-x: auto;
            padding: 10px 24px;
            scrollbar-width: none;
        }
        .category-bar-inner::-webkit-scrollbar { display: none; }

        .cat-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 16px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
            white-space: nowrap;
            text-decoration: none;
            border: 1.5px solid #e5e7eb;
            background: #f9fafb;
            color: #374151;
            transition: all 0.15s;
            flex-shrink: 0;
        }
        .cat-pill:hover { border-color: #667eea; color: #667eea; background: #f5f3ff; }
        .cat-pill.active { background: linear-gradient(135deg, #667eea, #764ba2); color: white; border-color: transparent; box-shadow: 0 2px 8px rgba(102,126,234,0.35); }
        .cat-pill .cat-count { font-size: 11px; font-weight: 500; opacity: 0.7; }

        /* ── Page header ──────────────────────────────────── */
        .list-header {
            max-width: 1280px;
            margin: 28px auto 20px;
            padding: 0 24px;
            display: flex;
            align-items: baseline;
            gap: 12px;
        }
        .list-header h1 { font-size: 22px; font-weight: 700; color: #111827; margin: 0; }
        .list-header .result-count { font-size: 14px; color: #9ca3af; }

        /* ── Product grid ─────────────────────────────────── */
        .product-grid {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px 56px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }

        /* ── Product card ─────────────────────────────────── */
        .product-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #e5e7eb;
            transition: box-shadow 0.2s, transform 0.2s;
            display: flex;
            flex-direction: column;
        }
        .product-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.1); transform: translateY(-3px); }
        .product-img-link { display: block; }
        .product-img-wrap {
            position: relative;
            height: 220px;
            overflow: hidden;
            background: #f3f4f6;
        }
        .product-img-wrap img {
            width: 100%; height: 100%;
            object-fit: cover;
            transition: transform 0.35s ease;
            display: block;
        }
        .product-card:hover .product-img-wrap img { transform: scale(1.05); }
        .product-img-placeholder {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            font-size: 3rem; color: #d1d5db;
        }
        .product-cat-badge {
            position: absolute; top: 10px; left: 10px;
            padding: 3px 10px; border-radius: 999px;
            font-size: 11px; font-weight: 600;
            background: rgba(255,255,255,0.93);
            color: #6d28d9;
        }
        .product-promo-badge {
            position: absolute; top: 10px; right: 10px;
            padding: 3px 10px; border-radius: 999px;
            font-size: 11px; font-weight: 700;
            background: #ef4444; color: white;
        }
        .product-body {
            padding: 14px 16px 16px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }
        .product-title {
            margin: 0 0 8px;
            font-size: 14px; font-weight: 600; color: #111827;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.45;
            flex-grow: 1;
        }
        .product-title a { color: inherit; text-decoration: none; }
        .product-title a:hover { color: #667eea; }
        .product-price { margin: 8px 0 0; }
        .product-price-current { font-size: 16px; font-weight: 700; color: #111827; }
        .product-price-current.sale { color: #ef4444; }
        .product-price-original { font-size: 12px; color: #9ca3af; text-decoration: line-through; margin-left: 6px; }
        .product-actions {
            display: flex; gap: 8px;
            margin-top: 14px; padding-top: 12px;
            border-top: 1px solid #f3f4f6;
        }
        .product-btn-cart {
            flex: 1; padding: 8px 10px;
            color: white; border: none; border-radius: 7px;
            font-size: 12px; font-weight: 600; cursor: pointer;
            display: inline-flex; align-items: center; justify-content: center; gap: 5px;
            transition: opacity 0.15s, transform 0.15s; width: 100%;
        }
        
        .product-btn-view {
            padding: 8px 12px; background: #f3f4f6; color: #374151;
            border-radius: 7px; font-size: 12px; font-weight: 600;
            text-decoration: none; white-space: nowrap;
            display: inline-flex; align-items: center;
            transition: background 0.15s; flex-shrink: 0;
        }
        .product-btn-view:hover { background: #e5e7eb; color: #111827; }

        /* ── Load more ────────────────────────────────────── */
        .load-more-wrap { text-align: center; padding: 8px 0 48px; }

        /* ── Empty state ──────────────────────────────────── */
        .empty-products {
            max-width: 420px; margin: 80px auto;
            text-align: center; padding: 0 24px;
        }
        .empty-products .ep-icon { font-size: 3.5rem; margin-bottom: 16px; }
        .empty-products h2 { font-size: 20px; font-weight: 600; color: #111827; margin: 0 0 8px; }
        .empty-products p { color: #6b7280; margin-bottom: 20px; }

        /* ── Responsive ───────────────────────────────────── */
        @media (max-width: 1100px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }
        @media (max-width: 768px) {
            .product-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; padding: 0 16px 32px; }
            .category-bar-inner { padding: 10px 16px; }
            .list-header { padding: 0 16px; margin: 20px auto 16px; }
        }
        @media (max-width: 480px) { .product-grid { grid-template-columns: 1fr; } }
    </style>
{% endblock %}

{% block body %}

{# ── Sticky category bar ──────────────────────────────────── #}
<div class="category-bar">
    <div class="category-bar-inner">
        <a href="{{ path('app_article_list') }}" class="cat-pill {{ activeCategory is null ? 'active' : '' }}">
            {{ 'articles.filter.all'|trans }}
        </a>
        {% for category in categories %}
            <a href="{{ path('app_article_list', {category: category.slug}) }}"
               class="cat-pill {{ activeCategory == category.slug ? 'active' : '' }}">
                {{ category.getTranslatedName(app.request.locale) }}
                <span class="cat-count">({{ categoryCounts[category.id] ?? 0 }})</span>
            </a>
        {% endfor %}
    </div>
</div>

{# ── Page header ──────────────────────────────────────────── #}
<div class="list-header">
    <h1>
        {% if activeCategory %}
            {% for cat in categories %}{% if cat.slug == activeCategory %}{{ cat.getTranslatedName(app.request.locale) }}{% endif %}{% endfor %}
        {% else %}
            {{ 'articles.title'|trans }}
        {% endif %}
    </h1>
    <span class="result-count">{{ total }} {{ total == 1 ? 'common.article'|trans : 'common.articles'|trans }}</span>
</div>

{# ── Products ─────────────────────────────────────────────── #}
{% if articles is empty %}
    <div class="empty-products">
        <div class="ep-icon">🛍️</div>
        <h2>{{ 'articles.empty.title'|trans }}</h2>
        <p>{{ 'articles.empty.description'|trans }}</p>
        {% if activeCategory %}
            <a href="{{ path('app_article_list') }}" class="btn-action-secondary">
                {{ 'articles.filter.all'|trans }}
            </a>
        {% endif %}
    </div>
{% else %}
    <div class="product-grid" id="article-grid">
        {% include 'article/_cards.html.twig' %}
    </div>

    {% if hasMore %}
    <div class="load-more-wrap" id="load-more-wrapper">
        <button
            id="load-more-btn"
            class="btn-action-primary"
            data-offset="{{ nextOffset }}"
            data-base-url="{{ path('app_article_list') }}{% if activeCategory %}?category={{ activeCategory }}&{% else %}?{% endif %}"
            style="min-width: 200px;"
        >
            {{ 'articles.load_more'|trans }}
        </button>
    </div>
    {% endif %}
{% endif %}

<script>
(function () {
    var btn = document.getElementById('load-more-btn');
    if (!btn) return;
    btn.addEventListener('click', async function () {
        var offset = btn.dataset.offset;
        var url    = btn.dataset.baseUrl + 'offset=' + offset;
        btn.disabled = true;
        btn.textContent = '{{ 'common.loading'|trans }}';
        try {
            var resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            var data = await resp.json();
            document.getElementById('article-grid').insertAdjacentHTML('beforeend', data.html);
            if (typeof initCartForms === 'function') initCartForms();
            if (data.hasMore) {
                btn.dataset.offset = data.nextOffset;
                btn.disabled = false;
                btn.textContent = '{{ 'articles.load_more'|trans }}';
            } else {
                document.getElementById('load-more-wrapper').remove();
            }
        } catch (e) {
            btn.disabled = false;
            btn.textContent = '{{ 'articles.load_more'|trans }}';
        }
    });
})();
</script>

{% endblock %}
