{% extends 'base.html.twig' %}

{% block title %}{{ 'article_form.edit_title'|trans }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/custom.css') }}">
{% endblock %}

{% block body %}
<div style="background: #f4f6f9; min-height: calc(100vh - 4rem);">

    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'article-edit-form'}}) }}

    {# Page header bar #}
    <div style="background: white; border-bottom: 1px solid #d6dde6; padding: 0 32px;">
        <div style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; height: 64px;">
            <div>
                <p style="margin: 0 0 2px 0; font-size: 12px; color: #8a9ab5;">
                    <a href="{{ path('app_article_list') }}" style="color: #8a9ab5; text-decoration: none;">Articles</a>
                    &nbsp;/&nbsp;
                    <a href="{{ path('app_article_show', {id: article.id}) }}" style="color: #8a9ab5; text-decoration: none;">{{ article.title|slice(0,30) }}{% if article.title|length > 30 %}…{% endif %}</a>
                    &nbsp;/&nbsp;{{ 'article_form.edit_title'|trans }}
                </p>
                <h1 style="margin: 0; font-size: 1.35rem; font-weight: 700; color: #1a2340; letter-spacing: -0.01em;">
                    {{ 'article_form.edit_title'|trans }}
                </h1>
            </div>
            <div style="display: flex; gap: 10px; align-items: center;">
                <a href="{{ path('app_article_show', {id: article.id}) }}" class="btn-action-secondary">
                    <i class="bi bi-x-lg"></i> {{ 'article_form.cancel'|trans }}
                </a>
                <button type="submit" form="article-edit-form" class="btn-action-primary">
                    <i class="bi bi-check-lg"></i> {{ 'article_form.save_changes'|trans }}
                </button>
            </div>
        </div>
    </div>

    {# Page content #}
    <div style="max-width: 1200px; margin: 28px auto; padding: 0 32px;">

        <div style="background: white; border: 1px solid #d6dde6; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
            <div style="padding: 16px 24px; background: #f8fafc; border-bottom: 1px solid #d6dde6;">
                <h2 style="margin: 0; font-size: 14px; font-weight: 700; color: #1a2340; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.form.info_title'|trans }}</h2>
            </div>
            <div style="padding: 28px 24px; display: flex; flex-direction: column; gap: 24px;">

                <div>
                    {{ form_label(form.title, 'article_form.title_label'|trans, {
                        'label_attr': {
                            'style': 'display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;'
                        }
                    }) }}
                    {{ form_widget(form.title, {
                        'attr': {
                            'placeholder': 'article_form.title_placeholder'|trans,
                            'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; color: #1a2340; background: #f8fafc; box-sizing: border-box; transition: border-color 0.2s;'
                        }
                    }) }}
                    <div style="color: #dc2626; font-size: 13px; margin-top: 4px;">{{ form_errors(form.title) }}</div>
                </div>

                <div>
                    {{ form_label(form.content, 'article_form.content_label'|trans, {
                        'label_attr': {
                            'style': 'display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;'
                        }
                    }) }}
                    {{ form_widget(form.content, {
                        'attr': {
                            'placeholder': 'article_form.content_placeholder'|trans,
                            'style': 'width: 100%; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; color: #1a2340; background: #f8fafc; box-sizing: border-box; min-height: 280px; resize: vertical; line-height: 1.6; transition: border-color 0.2s;'
                        }
                    }) }}
                    <div style="color: #dc2626; font-size: 13px; margin-top: 4px;">{{ form_errors(form.content) }}</div>
                </div>

            </div>
        </div>

        {# Pricing card #}
        <div style="background: white; border: 1px solid #d6dde6; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); margin-top: 20px;">
            <div style="padding: 16px 24px; background: #f8fafc; border-bottom: 1px solid #d6dde6;">
                <h2 style="margin: 0; font-size: 14px; font-weight: 700; color: #1a2340; text-transform: uppercase; letter-spacing: 0.05em;">{{ 'admin.articles.form.pricing_title'|trans }}</h2>
            </div>
            <div style="padding: 28px 24px;">
                {{ form_label(form.price, 'article_form.price_label'|trans, {
                    'label_attr': {
                        'style': 'display: block; margin-bottom: 6px; font-size: 13px; font-weight: 600; color: #374155; text-transform: uppercase; letter-spacing: 0.04em;'
                    }
                }) }}
                <div style="display: flex; align-items: center; gap: 8px;">
                    {{ form_widget(form.price, {
                        'attr': {
                            'style': 'width: 200px; padding: 10px 14px; border: 1px solid #d6dde6; border-radius: 6px; font-size: 15px; color: #1a2340; background: #f8fafc; box-sizing: border-box;'
                        }
                    }) }}
                    <span style="font-size: 14px; color: #8a9ab5;">$</span>
                </div>
                <div style="color: #dc2626; font-size: 13px; margin-top: 4px;">{{ form_errors(form.price) }}</div>
            </div>
        </div>

        {# Bottom save bar #}
        <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; padding-bottom: 32px;">
            <a href="{{ path('app_article_show', {id: article.id}) }}" class="btn-action-secondary">
                <i class="bi bi-x-lg"></i> {{ 'article_form.cancel'|trans }}
            </a>
            <button type="submit" form="article-edit-form" class="btn-action-primary">
                <i class="bi bi-check-lg"></i> {{ 'article_form.save_changes'|trans }}
            </button>
        </div>

    </div>

    {{ form_end(form) }}

</div>
{% endblock %}
