<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Mon Application{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
            <link rel="stylesheet" href="{{ asset('styles/custom.css') }}">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="h-full bg-zinc-50 antialiased">
        {# Navigation minimaliste #}
        <nav class="sticky top-0 z-50 bg-white border-b border-zinc-200 shadow-sm">
            <div class="max-w-7xl mx-auto px-6">
                <div class="flex justify-between items-center h-16">

    {# Logo #}
    <a href="{{ path('app_article_list') }}" 
       style="display: flex; align-items: center; gap: 0.5rem; font-size: 1.125rem; font-weight: 600; color: #18181b; text-decoration: none;">
        <svg style="width: 1.5rem; height: 1.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        MonApp
    </a>

    {# Droite #}
    {% set current_route = app.request.attributes.get('_route') %}
    {% set route_params = app.request.attributes.get('_route_params') %}

    <div style="display: flex; align-items: center; gap: 1.25rem;">

        {# Switch de langue #}
        <div style="display: flex; align-items: center; gap: 0.1rem;">
            <a href="{{ path(current_route, route_params|merge({'_locale': 'fr'})) }}"
               style="font-size: 0.75rem; font-weight: {{ app.request.locale == 'fr' ? '600' : '400' }}; color: {{ app.request.locale == 'fr' ? '#18181b' : '#a1a1aa' }}; text-decoration: none; padding: 0.2rem 0.4rem; letter-spacing: 0.03em;">
                FR
            </a>
            <span style="color: #d4d4d8; font-size: 0.7rem;">|</span>
            <a href="{{ path(current_route, route_params|merge({'_locale': 'en'})) }}"
               style="font-size: 0.75rem; font-weight: {{ app.request.locale == 'en' ? '600' : '400' }}; color: {{ app.request.locale == 'en' ? '#18181b' : '#a1a1aa' }}; text-decoration: none; padding: 0.2rem 0.4rem; letter-spacing: 0.03em;">
                EN
            </a>
        </div>

        {# Panier #}
        <a class="cart-nav-link" href="{{ path('app_cart_index') }}">
            {% set itemCount = app.request.session.get('cart_id') ? cart_service.getItemCount() : 0 %}
            <span class="cart-icon-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                {% if itemCount > 0 %}
                    <span class="cart-badge-count">{{ itemCount }}</span>
                {% endif %}
            </span>
        </a>

    </div>
</div>
            </div>
        </nav>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ type }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Contenu principal #}
        <main>
            {% block body %}{% endblock %}
        </main>

        {# Footer minimaliste #}
        <footer class="border-t border-zinc-200 bg-white mt-12">
            <div class="max-w-7xl mx-auto px-6 py-6">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                    <p class="text-sm text-zinc-500">
                        © {{ "now"|date("Y") }} MonApp
                    </p>
                    <div class="flex gap-6 text-sm text-zinc-600">
                        <a href="#" class="hover:text-zinc-900 transition-colors">Documentation</a>
                        <a href="#" class="hover:text-zinc-900 transition-colors">Support</a>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>