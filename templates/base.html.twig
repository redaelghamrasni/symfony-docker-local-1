<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}{{ 'base.app_name'|trans }}{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
            <link rel="stylesheet" href="{{ asset('styles/custom.css') }}">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="h-full bg-zinc-50 antialiased">
        {# Navigation minimaliste #}
        <nav class="sticky top-0 z-50 bg-white border-b border-zinc-200 shadow-sm">
            <div class="max-w-7xl mx-auto px-6">
                <div class="flex justify-between items-center h-16">

    {# Logo #}
    <a href="{{ path('app_home') }}" 
       style="display: flex; align-items: center; gap: 0.5rem; font-size: 1.125rem; font-weight: 600; color: #18181b; text-decoration: none;">
        <svg style="width: 1.5rem; height: 1.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        {{ 'nav.app_name'|trans }}
    </a>

    {# Autocomplete searchbar #}
    <div id="nav-search-wrapper" style="flex: 1; max-width: 320px; position: relative;">
        <div style="position: relative; display: flex; align-items: center;">
            <i class="bi bi-search" style="position: absolute; left: 11px; color: #94a3b8; font-size: 0.8rem; pointer-events: none;"></i>
            <input
                id="nav-search-input"
                type="text"
                autocomplete="off"
                spellcheck="false"
                placeholder="{{ 'search.placeholder'|trans }}"
                data-search-url="{{ path('app_search_index') }}"
                data-locale="{{ app.request.locale }}"
                data-label-view-all="{{ 'search.view_all'|trans }}"
                data-label-no-results="{{ 'search.no_results'|trans }}"
                class="nav-search-input"
            >
        </div>
        <div id="nav-search-dropdown" class="nav-search-dropdown" style="display: none;"></div>
    </div>

    {# Droite #}

    <div style="display: flex; align-items: center; gap: 1.25rem;">

        {# Switch de langue #}
        <div style="display: flex; align-items: center; gap: 0.1rem;">
            <a href="{{ path('app_switch_locale', {locale: 'fr'}) }}"
               style="font-size: 0.75rem; font-weight: {{ app.request.locale == 'fr' ? '600' : '400' }}; color: {{ app.request.locale == 'fr' ? '#18181b' : '#a1a1aa' }}; text-decoration: none; padding: 0.2rem 0.4rem; letter-spacing: 0.03em;">
                FR
            </a>
            <span style="color: #d4d4d8; font-size: 0.7rem;">|</span>
            <a href="{{ path('app_switch_locale', {locale: 'en'}) }}"
               style="font-size: 0.75rem; font-weight: {{ app.request.locale == 'en' ? '600' : '400' }}; color: {{ app.request.locale == 'en' ? '#18181b' : '#a1a1aa' }}; text-decoration: none; padding: 0.2rem 0.4rem; letter-spacing: 0.03em;">
                EN
            </a>
        </div>

        {# Panier #}
        <a class="cart-nav-link" href="{{ path('app_cart_index') }}">
            {% set itemCount = app.request.session.get('cart_id') ? cart_service.getItemCount() : 0 %}
            <span class="cart-icon-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                {% if itemCount > 0 %}
                    <span class="cart-badge-count">{{ itemCount }}</span>
                {% endif %}
            </span>
        </a>

        {# Authentication #}
        {% if app.user %}
            <div class="user-dropdown" id="userDropdown">
                <button class="user-dropdown-trigger btn-action-secondary" onclick="toggleUserDropdown(event)">
                    <i class="bi bi-person-circle"></i>
                    {{ 'nav.welcome'|trans({'%name%': app.user.getFirstName()}) }}
                    <i class="bi bi-chevron-down" style="font-size: 0.65rem;"></i>
                </button>
                <div class="user-dropdown-menu" id="userDropdownMenu">
                    <div class="user-dropdown-header">
                        <div class="user-dropdown-name">{{ app.user.getFirstName() }} {{ app.user.getLastName() }}</div>
                        <div class="user-dropdown-email">{{ app.user.email }}</div>
                    </div>
                    <a href="{{ path('app_profile_index') }}">
                        <i class="bi bi-person"></i> {{ 'profile.index.title'|trans }}
                    </a>
                    <a href="{{ path('app_profile_orders') }}">
                        <i class="bi bi-bag"></i> {{ 'profile.orders.title'|trans }}
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <hr class="user-dropdown-divider">
                        <a href="{{ path('admin_dashboard') }}">
                            <i class="bi bi-speedometer2"></i> {{ 'nav.admin'|trans }}
                        </a>
                    {% endif %}
                    <hr class="user-dropdown-divider">
                    <a href="{{ path('app_auth_logout') }}" class="user-dropdown-logout">
                        <i class="bi bi-box-arrow-right"></i> {{ 'profile.logout'|trans }}
                    </a>
                </div>
            </div>
        {% else %}
            <a href="{{ path('app_auth_login') }}" style="font-size: 0.875rem; color: #374151; text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 6px; border: 1px solid #e5e7eb;">
                {{ 'auth.login.submit' | trans }}
            </a>
            <a href="{{ path('app_auth_register') }}" style="font-size: 0.875rem; color: #fff; text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 6px; background: #0f172a; border: 1px solid #0f172a;">
                {{ 'auth.register.submit' | trans }}
            </a>
        {% endif %}

    </div>
</div>
            </div>
        </nav>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ type }}">
                    {{ message | trans }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Contenu principal #}
        <main>
            {% block body %}{% endblock %}
        </main>

        {# Footer minimaliste #}
        <footer class="border-t border-zinc-200 bg-white mt-12">
            <div class="max-w-7xl mx-auto px-6 py-6">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                    <p class="text-sm text-zinc-500">
                        © {{ "now"|date("Y") }} {{ 'nav.app_name'|trans }}
                    </p>
                    <div class="flex gap-6 text-sm text-zinc-600">
                        <a href="#" class="hover:text-zinc-900 transition-colors">{{ 'footer.documentation'|trans }}</a>
                        <a href="#" class="hover:text-zinc-900 transition-colors">{{ 'footer.support'|trans }}</a>
                    </div>
                </div>
            </div>
        </footer>
        {# Toast notification #}
<div id="cart-toast" style="
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 9999;
    background: #0f172a;
    color: #fff;
    padding: 14px 20px;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    display: none;
    flex-direction: column;
    gap: 10px;
    max-width: 320px;
    transition: opacity 0.3s ease;
">
    <div style="display: flex; align-items: center; gap: 10px;">
        <img id="cart-toast-img" src="" alt="" style="width: 56px; height: 56px; object-fit: cover; border-radius: 6px; flex-shrink: 0; display: none;">
        <div style="display: flex; align-items: center; gap: 8px; min-width: 0;">
            <i class="bi bi-check-circle-fill" style="color: #10b981; font-size: 1.1rem; flex-shrink: 0;"></i>
            <span id="cart-toast-message" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></span>
        </div>
    </div>
    <div style="display: flex; gap: 8px; margin-top: 4px;">
        <a href="{{ path('app_cart_index') }}" 
           style="flex: 1; text-align: center; padding: 7px 12px; background: #fff; color: #0f172a; border-radius: 6px; font-size: 0.8rem; font-weight: 600; text-decoration: none; transition: background 0.15s;">
            <i class="bi bi-cart3"></i> {{ 'cart.view_cart'|trans }}
        </a>
        {% if app.user %}
        <a href="{{ path('app_checkout_index') }}"
           style="flex: 1; text-align: center; padding: 7px 12px; background: #2563eb; color: #fff; border-radius: 6px; font-size: 0.8rem; font-weight: 600; text-decoration: none; transition: background 0.15s;">
            <i class="bi bi-credit-card"></i> {{ 'checkout.title'|trans }}
        </a>
        {% else %}
        <button onclick="openCheckoutModal()"
                style="flex: 1; text-align: center; padding: 7px 12px; background: #2563eb; color: #fff; border-radius: 6px; font-size: 0.8rem; font-weight: 600; border: none; cursor: pointer; transition: background 0.15s;">
            <i class="bi bi-credit-card"></i> {{ 'checkout.title'|trans }}
        </button>
        {% endif %}
        <button onclick="closeToast()" 
                style="background: none; border: none; color: #94a3b8; cursor: pointer; padding: 7px 6px; font-size: 1rem; line-height: 1; flex-shrink: 0;">
            ✕
        </button>
    </div>
</div>

<script>
    var translations = {};

    function loadTranslations() {
        translations = {
            cartError: "{{ 'cart.error_adding'|trans }}",
        };
    }

    loadTranslations();
    document.addEventListener('turbo:load', function() {
        loadTranslations();
    });

    function closeToast() {
        const toast = document.getElementById('cart-toast');
        if (!toast) return;
        toast.style.opacity = '0';
        setTimeout(() => { toast.style.display = 'none'; }, 300);
    }

    function showToast(message, imageUrl) {
        const toast = document.getElementById('cart-toast');
        document.getElementById('cart-toast-message').textContent = message;

        const img = document.getElementById('cart-toast-img');
        if (imageUrl) {
            img.src = imageUrl;
            img.style.display = 'block';
        } else {
            img.style.display = 'none';
        }

        toast.style.display = 'flex';
        toast.style.opacity = '1';

        setTimeout(() => {
            toast.style.opacity = '0';
            setTimeout(() => { toast.style.display = 'none'; }, 2300);
        }, 15000);
    }

    function updateCartBadge(count) {
        const badge = document.querySelector('.cart-badge-count');
        if (count > 0) {
            if (badge) {
                badge.textContent = count;
            } else {
                const wrapper = document.querySelector('.cart-icon-wrapper');
                if (wrapper) {
                    const newBadge = document.createElement('span');
                    newBadge.className = 'cart-badge-count';
                    newBadge.textContent = count;
                    wrapper.appendChild(newBadge);
                }
            }
        }
    }

    function initCartForms() {
        document.querySelectorAll('.form-add-to-cart').forEach(form => {
            if (form.dataset.ajaxInit) return;
            form.dataset.ajaxInit = '1';

            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const url = form.dataset.url;
                const button = form.querySelector('button[type="submit"]');
                const originalContent = button.innerHTML;

                button.disabled = true;
                button.innerHTML = '<i class="bi bi-hourglass-split"></i>';

                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: new FormData(form),
                    });

                    const data = await response.json();

                    if (data.success) {
                        showToast(data.message, data.imageUrl);
                        updateCartBadge(data.itemCount);
                    }
                } catch (err) {
                    showToast(translations.cartError);
                } finally {
                    button.disabled = false;
                    button.innerHTML = originalContent;
                }
            });
        });
    }

    document.addEventListener('DOMContentLoaded', initCartForms);
    document.addEventListener('turbo:load', initCartForms);

    function toggleUserDropdown(e) {
        e.stopPropagation();
        document.getElementById('userDropdownMenu').classList.toggle('open');
    }

    document.addEventListener('click', function() {
        const menu = document.getElementById('userDropdownMenu');
        if (menu) menu.classList.remove('open');
    });

    function openCheckoutModal() {
        const overlay = document.getElementById('checkout-modal-overlay');
        if (overlay) overlay.style.display = 'flex';
    }

    function closeCheckoutModal() {
        const overlay = document.getElementById('checkout-modal-overlay');
        if (overlay) overlay.style.display = 'none';
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeCheckoutModal();
    });
    </script>

{% if not app.user %}
{# ── Guest / Login modal — shared by toast and cart checkout buttons ── #}
<div id="checkout-modal-overlay" style="
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,0.5);
    z-index: 10000;
    align-items: center;
    justify-content: center;
" onclick="if(event.target===this)closeCheckoutModal()">
    <style>
        @keyframes ccModalIn {
            from { opacity: 0; transform: translateY(14px) scale(0.98); }
            to   { opacity: 1; transform: translateY(0)    scale(1);    }
        }
        #checkout-modal-box { animation: ccModalIn 0.2s ease; }
    </style>
    <div id="checkout-modal-box" style="
        background: #fff;
        border-radius: 18px;
        padding: 2rem 1.75rem 1.75rem;
        max-width: 360px;
        width: calc(100% - 2rem);
        box-shadow: 0 28px 60px rgba(15,23,42,0.22);
        position: relative;
    ">
        <button onclick="closeCheckoutModal()" style="
            position:absolute; top:14px; right:16px;
            background:none; border:none; color:#94a3b8;
            font-size:1.1rem; cursor:pointer; line-height:1; padding:4px;
        " aria-label="Close">✕</button>

        <div style="margin-bottom:1.25rem;">
            <p style="font-size:0.78rem;font-weight:600;color:#6366f1;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 0.5rem;">
                {{ 'cart.checkout'|trans }}
            </p>
            <h3 style="margin:0 0 0.4rem;font-size:1.15rem;font-weight:700;color:#0f172a;">
                {{ 'checkout.modal.title'|trans }}
            </h3>
            <p style="margin:0;color:#64748b;font-size:0.875rem;line-height:1.6;">
                {{ 'checkout.modal.description'|trans }}
            </p>
        </div>

        <div style="display:flex;flex-direction:column;gap:10px;">
            <a href="{{ path('app_auth_login') }}?redirect={{ path('app_checkout_index')|url_encode }}" style="
                display:flex;align-items:center;justify-content:center;gap:8px;
                padding:12px 20px;
                background:#0f172a;color:#fff;
                border-radius:10px;font-weight:600;font-size:0.9rem;
                text-decoration:none;transition:background 0.15s;
            " onmouseover="this.style.background='#1e293b'" onmouseout="this.style.background='#0f172a'">
                <i class="bi bi-person-check"></i>
                {{ 'checkout.modal.login'|trans }}
            </a>
            <a href="{{ path('app_checkout_index') }}" style="
                display:flex;align-items:center;justify-content:center;gap:8px;
                padding:12px 20px;
                background:#fff;color:#0f172a;
                border:1.5px solid #e2e8f0;border-radius:10px;
                font-weight:600;font-size:0.9rem;
                text-decoration:none;transition:background 0.15s;
            " onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='#fff'">
                <i class="bi bi-person-dash"></i>
                {{ 'checkout.modal.guest'|trans }}
            </a>
        </div>
    </div>
</div>
{% endif %}
{# InstantSearch via CDN #}
<script src="https://cdn.jsdelivr.net/npm/@meilisearch/instant-meilisearch/dist/instant-meilisearch.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/instantsearch.js@4/dist/instantsearch.production.min.js"></script>
<script>
function initSearch() {
    const container = document.getElementById('searchbox-container');
    if (!container) return;
    if (container.dataset.searchInit === '1') return;
    container.dataset.searchInit = '1';

    const locale = document.documentElement.lang || 'fr';

    const { searchClient } = instantMeiliSearch(
        'http://localhost:7700',
        'changeme_master_key_dev',
    );

    const search = instantsearch({
        indexName: 'articles',
        searchClient,
    });

    container.style.position = 'relative';
    container.innerHTML = `
        <div class="search-autocomplete">
            <input type="text" 
                   class="search-autocomplete-input" 
                   placeholder="${locale === 'fr' ? 'Rechercher un article...' : 'Search for an article...'}"
                   autocomplete="off">
            <div class="search-autocomplete-dropdown" style="display: none;">
                <div class="search-autocomplete-hits"></div>
                <a href="/${locale}/search" class="search-autocomplete-footer">
                    ${locale === 'fr' ? 'Voir tous les résultats' : 'View all results'} →
                </a>
            </div>
        </div>
    `;

    const input    = container.querySelector('.search-autocomplete-input');
    const dropdown = container.querySelector('.search-autocomplete-dropdown');
    const hitsDiv  = container.querySelector('.search-autocomplete-hits');
    const footer   = container.querySelector('.search-autocomplete-footer');

    const customSearchBox = instantsearch.connectors.connectSearchBox((renderOptions) => {
        const { refine } = renderOptions;

        input.addEventListener('input', () => {
            const query = input.value.trim();
            refine(query);
            if (query.length === 0) {
                dropdown.style.display = 'none';
            }
        });

        input.addEventListener('focus', () => {
            if (input.value.trim().length > 0 && hitsDiv.children.length > 0) {
                dropdown.style.display = 'block';
            }
        });
    });

    const customHits = instantsearch.connectors.connectHits((renderOptions) => {
        const { hits } = renderOptions;
        const query = input.value.trim();

        if (query.length === 0 || hits.length === 0) {
            if (query.length > 0 && hits.length === 0) {
                hitsDiv.innerHTML = `
                    <div class="search-autocomplete-empty">
                        ${locale === 'fr' ? 'Aucun résultat' : 'No results'}
                    </div>
                `;
                footer.style.display = 'none';
                dropdown.style.display = 'block';
            } else {
                dropdown.style.display = 'none';
            }
            return;
        }

        const displayHits = hits.slice(0, 5);

        hitsDiv.innerHTML = displayHits.map(hit => `
            <a href="/${locale}/article/${hit.id}" class="search-autocomplete-item">
                <div class="search-autocomplete-item-title">${highlightText(hit.title, query)}</div>
                <div class="search-autocomplete-item-bottom">
                    <span class="search-autocomplete-item-price">${parseFloat(hit.price).toFixed(2)} $</span>
                    ${hit.content ? `<span class="search-autocomplete-item-desc">${truncateText(hit.content, 60)}</span>` : ''}
                </div>
            </a>
        `).join('');

        footer.href = `/${locale}/search?q=${encodeURIComponent(query)}`;
        footer.style.display = 'block';
        dropdown.style.display = 'block';
    });

    search.addWidgets([
        customSearchBox({}),
        customHits({}),
    ]);

    search.start();

    document.addEventListener('click', (e) => {
        if (!container.contains(e.target)) {
            dropdown.style.display = 'none';
        }
    });

    input.addEventListener('keydown', (e) => {
        const items = dropdown.querySelectorAll('.search-autocomplete-item');
        const active = dropdown.querySelector('.search-autocomplete-item.active');
        let index = Array.from(items).indexOf(active);

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            index = Math.min(index + 1, items.length - 1);
            items.forEach(i => i.classList.remove('active'));
            items[index]?.classList.add('active');
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            index = Math.max(index - 1, 0);
            items.forEach(i => i.classList.remove('active'));
            items[index]?.classList.add('active');
        } else if (e.key === 'Enter') {
            if (active) {
                e.preventDefault();
                window.location.href = active.href;
            } else if (input.value.trim()) {
                e.preventDefault();
                window.location.href = `/${locale}/search?q=${encodeURIComponent(input.value.trim())}`;
            }
        } else if (e.key === 'Escape') {
            dropdown.style.display = 'none';
            input.blur();
        }
    });
}

function highlightText(text, query) {
    if (!query) return text;
    const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return text.replace(regex, '<mark>$1</mark>');
}

function truncateText(text, max) {
    return text.length > max ? text.substring(0, max) + '…' : text;
}

document.addEventListener('DOMContentLoaded', initSearch);
document.addEventListener('turbo:load', initSearch);
</script>
    </body>
</html>