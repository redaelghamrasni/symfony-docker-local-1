{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div style="
    min-height: 100vh;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
">
    <div style="
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        padding: 40px;
        max-width: 400px;
        width: 100%;
    ">
        <h1 style="
            font-size: 28px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 10px 0;
            text-align: center;
        ">{{ 'auth.forgot_password.title' | trans }}</h1>
        
        <p style="
            font-size: 14px;
            color: #64748b;
            text-align: center;
            margin: 0 0 30px 0;
        ">{{ 'auth.forgot_password.subtitle' | trans }}</p>

        {% if app.flashes('info') %}
            <div style="
                background: #dbeafe;
                border-left: 4px solid #3b82f6;
                color: #1e40af;
                padding: 12px 16px;
                margin-bottom: 20px;
                border-radius: 4px;
                font-size: 14px;
            ">
                {% for message in app.flashes('info') %}
                    {{ message }}
                {% endfor %}
            </div>
        {% endif %}

        {{ form_start(form) }}
        
        <div style="margin-bottom: 20px;">
            {{ form_row(form.email, {
                attr: {
                    style: 'width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; font-family: inherit;',
                    placeholder: form.email.vars.attr.placeholder
                }
            }) }}
        </div>

        <button type="submit" style="
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 20px;
        " onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(15, 23, 42, 0.3)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='';">
            {{ 'auth.forgot_password.submit' | trans }}
        </button>

        {{ form_end(form) }}

        <div style="text-align: center;">
            <a href="{{ path('app_auth_login') }}" style="
                color: #0f172a;
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
                transition: color 0.2s ease;
            " onmouseover="this.style.color='#3b82f6';" onmouseout="this.style.color='#0f172a';">
                {{ 'auth.forgot_password.login_link' | trans }}
            </a>
        </div>
    </div>
</div>
{% endblock %}
