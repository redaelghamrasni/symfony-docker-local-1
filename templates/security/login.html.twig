{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .auth-shell {
            min-height: calc(100vh - 6rem);
            padding: 4rem 1.5rem 3rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at top left, rgba(79, 70, 229, 0.18), transparent 34%),
                        radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.13), transparent 28%),
                        #f8fafc;
        }
        .auth-grid {
            width: min(1150px, 100%);
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 2rem;
        }
        .auth-panel,
        .auth-card {
            border-radius: 2rem;
            box-shadow: 0 28px 80px rgba(15, 23, 42, 0.12);
        }
        .auth-panel {
            padding: 3rem;
            background: rgba(255,255,255,0.94);
            border: 1px solid rgba(226,232,240,0.85);
            backdrop-filter: blur(12px);
        }
        .auth-card {
            padding: 2.5rem;
            background: white;
            border: 1px solid #e5e7eb;
        }
        .auth-badge {
            display: inline-flex;
            gap: 0.4rem;
            align-items: center;
            border-radius: 999px;
            background: #eef2ff;
            color: #4338ca;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.65rem 0.9rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }
        .auth-title {
            margin-top: 2rem;
            font-size: clamp(2.2rem, 2.5vw, 3.6rem);
            line-height: 1.02;
            font-weight: 700;
            color: #111827;
        }
        .auth-copy {
            margin-top: 1.5rem;
            max-width: 42rem;
            color: #475569;
            line-height: 1.85;
            font-size: 1rem;
        }
        .auth-stat-grid {
            margin-top: 2.5rem;
            display: grid;
            gap: 1rem;
        }
        .auth-stat {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 1.5rem;
            padding: 1.5rem;
        }
        .auth-stat strong {
            display: block;
            color: #111827;
            font-size: 0.95rem;
            margin-bottom: 0.45rem;
        }
        .auth-stat span {
            color: #64748b;
            font-size: 0.95rem;
            line-height: 1.7;
        }
        .auth-header {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: flex-start;
        }
        .auth-heading {
            font-size: 2rem;
            font-weight: 700;
            color: #0f172a;
            margin-top: 0.65rem;
        }
        .auth-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.7rem 1rem;
            border-radius: 999px;
            font-size: 0.9rem;
            color: #334155;
            background: #f8fafc;
        }
        .auth-form {
            margin-top: 2rem;
            display: grid;
            gap: 1.25rem;
        }
        .auth-group {
            display: grid;
            gap: 0.45rem;
        }
        .auth-group label {
            font-size: 0.95rem;
            font-weight: 600;
            color: #334155;
        }
        .auth-input {
            width: 100%;
            border-radius: 1rem;
            padding: 1rem 1.1rem;
            border: 1px solid #d1d5db;
            background: #f8fafc;
            color: #0f172a;
            font-size: 0.98rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }
        .auth-input:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99,102,241,0.12);
        }
        .auth-button {
            width: 100%;
            margin-top: 0.5rem;
            padding: 1rem 1.15rem;
            border-radius: 1.1rem;
            border: none;
            font-size: 1rem;
            font-weight: 700;
            color: white;
            background: linear-gradient(135deg,#4f46e5,#0ea5e9);
            box-shadow: 0 18px 40px rgba(79,70,229,0.22);
            cursor: pointer;
            transition: transform 0.2s ease, background 0.2s ease;
        }
        .auth-button:hover {
            transform: translateY(-1px);
            background: linear-gradient(135deg,#4338ca,#0284c7);
        }
        .auth-footer {
            margin-top: 1.5rem;
            color: #64748b;
            font-size: 0.95rem;
            text-align: center;
        }
        .auth-footer a {
            color: #3b82f6;
            text-decoration: none;
            font-weight: 600;
        }
        .auth-error {
            border-radius: 1rem;
            padding: 1rem 1.1rem;
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            font-size: 0.95rem;
        }
        @media (max-width: 980px) {
            .auth-shell {
                padding: 1.25rem 1rem 2rem;
                align-items: flex-start;
            }
            .auth-grid {
                grid-template-columns: 1fr;
            }
            .auth-card {
                order: -1;
            }
        }
        @media (max-width: 600px) {
            .auth-panel {
                display: none;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="auth-shell">
    <div class="auth-grid">
        <section class="auth-panel">
            <span class="auth-badge">{{ 'auth.login.badge' | trans }}</span>
            <h1 class="auth-title">{{ 'auth.login.title' | trans }}</h1>
            <p class="auth-copy">{{ 'auth.login.subtitle' | trans }}</p>
            <div class="auth-stat-grid">
                <div class="auth-stat">
                    <strong>{{ 'base.my_cart' | trans }}</strong>
                    <span>{{ 'auth.login.email_hint' | trans }}</span>
                </div>
                <div class="auth-stat">
                    <strong>Secure Payment</strong>
                    <span>{{ 'auth.login.security_hint' | trans }}</span>
                </div>
            </div>
        </section>

        <section class="auth-card">
            <div class="auth-header">
                <div>
                    <p class="auth-badge">{{ 'auth.login.badge' | trans }}</p>
                    <h2 class="auth-heading">{{ 'auth.login.submit' | trans }}</h2>
                </div>
                <span class="auth-pill">{{ 'auth.login.pill' | trans }}</span>
            </div>

            <form class="auth-form" action="{{ path('app_auth_login') }}" method="post" data-turbo="false">
                {% if error %}
                    <div class="auth-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                {% if app.request.query.get('redirect') %}
                    <input type="hidden" name="_target_path" value="{{ app.request.query.get('redirect') }}">
                {% endif %}

                <div class="auth-group">
                    <label for="username">{{ 'auth.login.username_label' | trans }}</label>
                    <input id="username" name="_username" type="text" autocomplete="username" required value="{{ last_username }}" class="auth-input" placeholder="john@example.com">
                </div>
                <div class="auth-group">
                    <label for="password">{{ 'auth.login.password_label' | trans }}</label>
                    <input id="password" name="_password" type="password" autocomplete="current-password" required class="auth-input" placeholder="••••••••">
                </div>

                <button type="submit" class="auth-button">{{ 'auth.login.submit' | trans }}</button>
            </form>

            <p class="auth-footer">
                <a href="{{ path('app_forgot_password') }}">{{ 'auth.login.forgot_password' | trans }}</a>
            </p>
            <p class="auth-footer">{{ 'auth.login.register_text' | trans }} <a href="{{ path('app_auth_register') }}">{{ 'auth.login.register_link' | trans }}</a></p>
        </section>
    </div>
</div>
{% endblock %}
