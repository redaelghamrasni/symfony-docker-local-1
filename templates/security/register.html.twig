{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .auth-shell {
            min-height: calc(100vh - 6rem);
            padding: 4rem 1.5rem 3rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at top left, rgba(79, 70, 229, 0.18), transparent 34%),
                        radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.13), transparent 28%),
                        #f8fafc;
        }
        .auth-grid {
            width: min(1150px, 100%);
            display: grid;
            grid-template-columns: 1.4fr 1fr;
            gap: 2rem;
        }
        .auth-panel,
        .auth-card {
            border-radius: 2rem;
            box-shadow: 0 28px 80px rgba(15, 23, 42, 0.12);
        }
        .auth-panel {
            padding: 3rem;
            background: rgba(255,255,255,0.94);
            border: 1px solid rgba(226,232,240,0.85);
            backdrop-filter: blur(12px);
        }
        .auth-card {
            padding: 2.5rem;
            background: white;
            border: 1px solid #e5e7eb;
        }
        .auth-badge {
            display: inline-flex;
            gap: 0.4rem;
            align-items: center;
            border-radius: 999px;
            background: #eef2ff;
            color: #4338ca;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.65rem 0.9rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }
        .auth-title {
            margin-top: 2rem;
            font-size: clamp(2.2rem, 2.5vw, 3.6rem);
            line-height: 1.02;
            font-weight: 700;
            color: #111827;
        }
        .auth-copy {
            margin-top: 1.5rem;
            max-width: 42rem;
            color: #475569;
            line-height: 1.85;
            font-size: 1rem;
        }
        .auth-stat-grid {
            margin-top: 2.5rem;
            display: grid;
            gap: 1rem;
        }
        .auth-stat {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 1.5rem;
            padding: 1.5rem;
        }
        .auth-stat strong {
            display: block;
            color: #111827;
            font-size: 0.95rem;
            margin-bottom: 0.45rem;
        }
        .auth-stat span {
            color: #64748b;
            font-size: 0.95rem;
            line-height: 1.7;
        }
        .auth-header {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: flex-start;
        }
        .auth-heading {
            font-size: 2rem;
            font-weight: 700;
            color: #0f172a;
            margin-top: 0.65rem;
        }
        .auth-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.7rem 1rem;
            border-radius: 999px;
            font-size: 0.9rem;
            color: #334155;
            background: #f8fafc;
        }
        .auth-form {
            margin-top: 2rem;
            display: grid;
            gap: 1.25rem;
        }
        .auth-group {
            display: grid;
            gap: 0.45rem;
        }
        .auth-group label {
            font-size: 0.95rem;
            font-weight: 600;
            color: #334155;
        }
        .auth-input {
            width: 100%;
            border-radius: 1rem;
            padding: 1rem 1.1rem;
            border: 1px solid #d1d5db;
            background: #f8fafc;
            color: #0f172a;
            font-size: 0.98rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }
        .auth-input:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99,102,241,0.12);
        }
        .auth-button {
            width: 100%;
            margin-top: 0.5rem;
            padding: 1rem 1.15rem;
            border-radius: 1.1rem;
            border: none;
            font-size: 1rem;
            font-weight: 700;
            color: white;
            background: linear-gradient(135deg,#4f46e5,#0ea5e9);
            box-shadow: 0 18px 40px rgba(79,70,229,0.22);
            cursor: pointer;
            transition: transform 0.2s ease, background 0.2s ease;
        }
        .auth-button:hover {
            transform: translateY(-1px);
            background: linear-gradient(135deg,#4338ca,#0284c7);
        }
        .auth-footer {
            margin-top: 1.5rem;
            color: #64748b;
            font-size: 0.95rem;
            text-align: center;
        }
        .auth-footer a {
            color: #3b82f6;
            text-decoration: none;
            font-weight: 600;
        }
        .auth-error {
            border-radius: 1rem;
            padding: 1rem 1.1rem;
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            font-size: 0.95rem;
        }
        @media (max-width: 980px) {
            .auth-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="auth-shell">
    <div class="auth-grid">
        <section class="auth-panel">
            <span class="auth-badge">{{ 'auth.register.badge' | trans }}</span>
            <h1 class="auth-title">{{ 'auth.register.title' | trans }}</h1>
            <p class="auth-copy">{{ 'auth.register.subtitle' | trans }}</p>
            <div class="auth-stat-grid">
                <div class="auth-stat">
                    <strong>{{ 'base.my_cart' | trans }}</strong>
                    <span>{{ 'auth.register.addresses_hint' | trans }}</span>
                </div>
                <div class="auth-stat">
                    <strong>Premium security</strong>
                    <span>{{ 'auth.register.security_hint' | trans }}</span>
                </div>
            </div>
        </section>

        <section class="auth-card">
            <div class="auth-header">
                <div>
                    <p class="auth-badge">{{ 'auth.register.badge' | trans }}</p>
                    <h2 class="auth-heading">{{ 'auth.register.submit' | trans }}</h2>
                </div>
                <span class="auth-pill">{{ 'auth.register.pill' | trans }}</span>
            </div>

            {{ form_start(form, {'attr': {'class': 'auth-form', 'data-turbo': 'false'}}) }}
                <div class="auth-group">
                    <label for="{{ form.email.vars.id }}">{{ 'auth.register.email_label' | trans }}</label>
                    {{ form_widget(form.email, {'attr': {'class': 'auth-input', 'placeholder': 'john@example.com'}}) }}
                    {{ form_errors(form.email) }}
                </div>
                <div class="auth-group">
                    <label for="{{ form.username.vars.id }}">{{ 'auth.register.username_label' | trans }}</label>
                    {{ form_widget(form.username, {'attr': {'class': 'auth-input', 'placeholder': 'john_doe'}}) }}
                    {{ form_errors(form.username) }}
                </div>
                <div class="auth-group">
                    <label for="{{ form.first_name.vars.id }}">{{ 'auth.register.first_name_label' | trans }}</label>
                    {{ form_widget(form.first_name, {'attr': {'class': 'auth-input', 'placeholder': 'Jean'}}) }}
                    {{ form_errors(form.first_name) }}
                </div>
                <div class="auth-group">
                    <label for="{{ form.last_name.vars.id }}">{{ 'auth.register.last_name_label' | trans }}</label>
                    {{ form_widget(form.last_name, {'attr': {'class': 'auth-input', 'placeholder': 'Dupont'}}) }}
                    {{ form_errors(form.last_name) }}
                </div>
                <div class="auth-group">
                    <label for="{{ form.password.vars.id }}">{{ 'auth.register.password_label' | trans }}</label>
                    {{ form_widget(form.password, {'attr': {'class': 'auth-input', 'placeholder': '••••••••'}}) }}
                    {{ form_errors(form.password) }}
                </div>

                <button type="submit" class="auth-button">{{ 'auth.register.submit' | trans }}</button>
            {{ form_end(form) }}

            <p class="auth-footer">{{ 'auth.register.login_text' | trans }} <a href="{{ path('app_auth_login') }}">{{ 'auth.register.login_link' | trans }}</a></p>
        </section>
    </div>
</div>
{% endblock %}
