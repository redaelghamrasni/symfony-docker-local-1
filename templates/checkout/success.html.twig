{% extends 'base.html.twig' %}

{% block title %}{{ 'checkout.success.title'|trans }}{% endblock %}

{% block body %}
<div class="checkout-success-container">
    <div class="checkout-success-card card">
        <h1>✅ {{ 'checkout.success.title'|trans }}</h1>
        <p>{{ 'checkout.success.message'|trans }}</p>
        <a href="{{ path('app_article_list') }}" class="btn btn-custom btn-continue">
            {{ 'checkout.success.back'|trans }}
        </a>
    </div>
</div>
{% endblock %}
