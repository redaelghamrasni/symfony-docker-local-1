{% extends 'base.html.twig' %}

{% block title %}{{ 'profile.orders.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .orders-shell {
            min-height: calc(100vh - 6rem);
            padding: 4rem 1.5rem 3rem;
            background: radial-gradient(circle at top left, rgba(79, 70, 229, 0.18), transparent 34%),
                        radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.13), transparent 28%),
                        #f8fafc;
        }
        .orders-container {
            width: min(1200px, 100%);
            margin: 0 auto;
        }
        .orders-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        .orders-title {
            font-size: 2rem;
            font-weight: 700;
            color: #0f172a;
        }
        .orders-nav {
            display: flex;
            gap: 1rem;
        }
        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.5rem;
            border-radius: 1rem;
            border: 1px solid #e2e8f0;
            background: white;
            color: #374151;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }
        .btn-back:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }
        .orders-list {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
        .order-card {
            border-radius: 1.5rem;
            box-shadow: 0 10px 32px rgba(15, 23, 42, 0.08);
            background: white;
            border: 1px solid #e5e7eb;
            padding: 1.75rem;
            transition: all 0.3s ease;
        }
        .order-card:hover {
            box-shadow: 0 20px 56px rgba(15, 23, 42, 0.12);
            border-color: #d1d5db;
        }
        .order-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #f0f0f0;
        }
        .order-number {
            font-size: 1.1rem;
            font-weight: 700;
            color: #0f172a;
        }
        .order-id {
            font-size: 0.85rem;
            color: #6b7280;
        }
        .order-status {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 1rem;
            border-radius: 999px;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .order-status--pending {
            background: #fef3c7;
            color: #92400e;
        }
        .order-status--processing {
            background: #dbeafe;
            color: #1e40af;
        }
        .order-status--completed {
            background: #dcfce7;
            color: #166534;
        }
        .order-status--cancelled {
            background: #fee2e2;
            color: #991b1b;
        }
        .order-card-body {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 1.5rem;
        }
        .order-info {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        .order-info-label {
            font-size: 0.85rem;
            color: #6b7280;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .order-info-value {
            font-size: 0.95rem;
            color: #374151;
            margin: 0;
        }
        .order-total {
            text-align: right;
        }
        .order-amount {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
        }
        .order-items-summary {
            font-size: 0.9rem;
            color: #6b7280;
            margin-top: 0.5rem;
        }
        .order-card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1rem;
            border-top: 1px solid #f0f0f0;
        }
        .order-date {
            font-size: 0.85rem;
            color: #6b7280;
        }
        .order-actions {
            display: flex;
            gap: 0.75rem;
        }
        .btn-view-order {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: 0.75rem;
            border: none;
            background: linear-gradient(135deg, #4f46e5, #0ea5e9);
            color: white;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: transform 0.2s ease;
        }
        .btn-view-order:hover {
            transform: translateY(-1px);
        }
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            border-radius: 1.5rem;
            background: white;
            border: 1px solid #e5e7eb;
        }
        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        .empty-state-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.5rem;
        }
        .empty-state-text {
            color: #6b7280;
            margin-bottom: 1.5rem;
        }
        .btn-shop {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.5rem;
            border-radius: 1rem;
            border: none;
            background: linear-gradient(135deg, #4f46e5, #0ea5e9);
            color: white;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease;
        }
        .btn-shop:hover {
            transform: translateY(-1px);
        }
        @media (max-width: 768px) {
            .orders-header {
                flex-direction: column;
                gap: 1rem;
                align-items: flex-start;
            }
            .order-card-body {
                grid-template-columns: 1fr;
            }
            .order-card-footer {
                flex-direction: column;
                gap: 1rem;
                align-items: flex-start;
            }
            .order-total {
                text-align: left;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="orders-shell">
    <div class="orders-container">
        <div class="orders-header">
            <h1 class="orders-title">{{ 'profile.orders.title'|trans }}</h1>
            <div class="orders-nav">
                <a href="{{ path('app_profile_index') }}" class="btn-back">
                    <i class="bi bi-arrow-left"></i>
                    {{ 'profile.orders.back_profile'|trans }}
                </a>
            </div>
        </div>

        {% if orders|length > 0 %}
            <div class="orders-list">
                {% for order in orders %}
                    <div class="order-card">
                        <div class="order-card-header">
                            <div>
                                <div class="order-number">{{ 'profile.orders.order'|trans }} #{{ order.id }}</div>
                                <div class="order-id">{{ order.customerEmail }}</div>
                            </div>
                            <span class="order-status order-status--{{ order.status }}">
                                {{ ('profile.orders.status_' ~ order.status)|trans }}
                            </span>
                        </div>

                        <div class="order-card-body">
                            <div>
                                <div class="order-info">
                                    <div>
                                        <div class="order-info-label">{{ 'profile.orders.date'|trans }}</div>
                                        <p class="order-info-value">{{ order.createdAt|date('d/m/Y H:i') }}</p>
                                    </div>
                                    <div>
                                        <div class="order-info-label">{{ 'profile.orders.customer_name'|trans }}</div>
                                        <p class="order-info-value">{{ order.customerFirstName }} {{ order.customerLastName }}</p>
                                    </div>
                                    <div>
                                        <div class="order-info-label">{{ 'profile.orders.shipping_address'|trans }}</div>
                                        <p class="order-info-value">
                                            {{ order.shippingStreet }}<br>
                                            {{ order.shippingPostalCode }} {{ order.shippingCity }}
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="order-total">
                                <div>
                                    <div class="order-info-label">{{ 'profile.orders.total'|trans }}</div>
                                    <div class="order-amount">{{ order.total|number_format(2, ',', ' ') }} $</div>
                                    <div class="order-items-summary">
                                        {{ order.items|length }} {{ order.items|length == 1 ? 'profile.orders.item'|trans : 'profile.orders.items'|trans }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="order-card-footer">
                            <div class="order-date">{{ order.updatedAt ? order.updatedAt|date('d/m/Y') : order.createdAt|date('d/m/Y') }}</div>
                            <div class="order-actions">
                                <a href="{{ path('app_profile_order_show', {id: order.id}) }}" class="btn-action-primary">
                                    <i class="bi bi-eye"></i>
                                    {{ 'profile.orders.view_details'|trans }}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <div class="empty-state-icon">📦</div>
                <h2 class="empty-state-title">{{ 'profile.orders.no_orders'|trans }}</h2>
                <p class="empty-state-text">{{ 'profile.orders.no_orders_description'|trans }}</p>
                <a href="{{ path('app_article_list') }}" class="btn-action-primary">
                    <i class="bi bi-shop button-icon"></i>
                    {{ 'profile.orders.start_shopping'|trans }}
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
